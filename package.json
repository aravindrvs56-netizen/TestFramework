{
  "name": "takehome-finance-qa-automation",
  "version": "1.0.0",
  "description": "Production-quality UI and API test automation for OrangeHRM and Reqres",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test --headed",
    "allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "playwright",
    "automation",
    "qa",
    "allure",
    "orangehrm",
    "reqres"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "allure-commandline": "^2.34.0",
    "allure-playwright": "^3.2.2",
    "eslint": "^9.28.0",
    "globals": "^16.2.0"
  }
}
